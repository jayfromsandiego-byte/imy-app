# I Miss You Memorial — environment variables
# Copy to .env.local for local dev; set the real values in Vercel (Preview AND Production).
# Nothing secret is committed — this file only documents the keys the app expects.

# ── Current MVP (live): Airtable data + AI assist + uploads ──────────────
AIRTABLE_PAT=                       # Airtable personal access token (data.records:read/write)
AIRTABLE_BASE_ID=apparEJ9ZRhjp7joc  # "I Miss You Memorial" base (Tributes, Customers)
OPENAI_API_KEY=                     # enables /api/assist (writing helper); graceful fallback if unset
ASSIST_MODEL=gpt-4o-mini
BLOB_READ_WRITE_TOKEN=              # Vercel Blob for /api/upload (on Vercel a connected store uses OIDC)

# ── Planned: Auth.js (NextAuth v5) — customer login ─────────────────────
AUTH_SECRET=                        # openssl rand -base64 33
AUTH_URL=https://imissyoumemorial.com
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=                  # generated client-secret JWT; rotates ~every 6 months
AUTH_RESEND_KEY=                    # Resend API key for email magic links
EMAIL_FROM=hello@imissyoumemorial.com

# ── Planned: Supabase Postgres (via Prisma) — accounts + tributes ───────
DATABASE_URL=    # Supabase POOLED conn, port 6543, ?pgbouncer=true&connection_limit=1
DIRECT_URL=      # Supabase DIRECT conn, port 5432 (migrations only)

# ── Planned: Stripe (checkout + webhooks → tier unlock) ─────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS_MONTHLY=          # confirm $6 vs $9 /mo before minting
STRIPE_PRICE_ETERNAL=               # mint a clean $200 one-time price
